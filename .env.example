# Driftbase Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ============================================
# CORE DATABASE CONFIGURATION
# ============================================

# For local development: SQLite (default behavior, no config needed)
# DRIFTBASE_DB_PATH=~/.driftbase/runs.db

# For production PostgreSQL (if using Driftbase Pro or self-hosted):
# DATABASE_URL=postgresql://username:password@host:5432/database
# Note: SQLAlchemy async requires postgresql+asyncpg:// prefix
# DATABASE_URL=postgresql+asyncpg://username:password@host:5432/database

# ============================================
# API KEYS (Production)
# ============================================

# Driftbase Pro API Key (for cloud sync)
# DRIFTBASE_API_KEY=db_live_your_key_here

# OpenAI API Key (for agent instrumentation)
# OPENAI_API_KEY=sk-proj-your_key_here

# ============================================
# PRIVACY & COMPLIANCE
# ============================================

# Enable PII scrubbing (GDPR/EU AI Act compliance)
DRIFTBASE_SCRUB_PII=true

# Disable telemetry capture (for testing)
# DRIFTBASE_DISABLE_TELEMETRY=false

# ============================================
# PERFORMANCE TUNING
# ============================================

# Retention limit for local SQLite database
DRIFTBASE_LOCAL_RETENTION_LIMIT=100000

# Background queue size
DRIFTBASE_MAX_QUEUE_SIZE=10000

# ============================================
# COST TRACKING
# ============================================

# Configure your enterprise LLM rates (€ per 1M tokens)
DRIFTBASE_RATE_PROMPT_1M=2.50
DRIFTBASE_RATE_COMPLETION_1M=10.00

# ============================================
# DEPLOYMENT METADATA
# ============================================

# Default version label (if not set in @track decorator)
# DRIFTBASE_DEPLOYMENT_VERSION=v1.0.0

# Environment label (production, staging, dev)
# DRIFTBASE_ENVIRONMENT=production
