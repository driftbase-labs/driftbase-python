# Driftbase Configuration
# Copy to .env and fill in your values. Never commit .env.
#
# Driftbase runs 100% locally by default. No API keys required.

# ── Cost tracking (optional) ────────────────────────────
# Your LLM rates in € per 1M tokens
# DRIFTBASE_RATE_PROMPT_1M=2.50
# DRIFTBASE_RATE_COMPLETION_1M=10.00
