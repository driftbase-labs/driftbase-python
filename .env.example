# Driftbase Configuration Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
#
# This SDK runs 100% locally by default. No API keys are required for
# tracking, local diff, or analytics. All data stays on your machine.

# ============================================
# OPTIONAL: Local database path override
# ============================================
# By default, data is stored at ~/.driftbase/runs.db
# Only set this if you want a custom location
# DRIFTBASE_DB_PATH=~/.driftbase/runs.db

# ============================================
# OPTIONAL: Cloud dashboard API access
# ============================================
# Only set if you use the cloud dashboard to view runs, drifts, and analytics.
# Required for: driftbase push, driftbase diff --remote
# DRIFTBASE_API_KEY=your_key_here
# DRIFTBASE_API_URL=https://api.driftbase.io

# ============================================
# PRIVACY & COMPLIANCE
# ============================================

# Enable PII scrubbing (GDPR/EU AI Act compliance)
DRIFTBASE_SCRUB_PII=true

# ============================================
# PERFORMANCE TUNING
# ============================================

# Retention limit for local SQLite database
DRIFTBASE_LOCAL_RETENTION_LIMIT=100000

# Background queue size
DRIFTBASE_MAX_QUEUE_SIZE=10000

# ============================================
# COST TRACKING
# ============================================

# Configure your enterprise LLM rates (€ per 1M tokens)
DRIFTBASE_RATE_PROMPT_1M=2.50
DRIFTBASE_RATE_COMPLETION_1M=10.00

# ============================================
# DEPLOYMENT METADATA
# ============================================

# Default version label (if not set in @track decorator)
# DRIFTBASE_DEPLOYMENT_VERSION=v1.0.0

# Environment label (production, staging, dev)
# DRIFTBASE_ENVIRONMENT=production
